# ── Salesforce Credentials ──
SF_USERNAME=your_salesforce_username@example.com
SF_PASSWORD=your_salesforce_password
SF_SECURITY_TOKEN=your_security_token_from_sf_settings
SF_DOMAIN=login           # "login" for production, "test" for sandbox

# ── App Settings ──
FLATTEN_PDF=true           # Flatten PDF after filling (non-editable)
UPLOAD_TO_SF=false         # Auto-upload filled PDF back to Salesforce
EMAIL_FILLED_PDF=false     # Email filled PDF to contact

# ── API Server (for n8n integration) ──
API_HOST=0.0.0.0
API_PORT=8100

# ── Optional ──
DATE_FORMAT=%Y-%m-%d
SF_API_VERSION=59.0
